doctype html
html
  head
    meta charset="utf-8"
    meta name="viewport" content="width=device-width, initial-scale=1"
    title Lucky Bet
    link rel="preconnect" href="https://fonts.googleapis.com"
    link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""
    link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet"
    style
      |
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
          --green-bright: #39ff14;
          --green-mid: #22c55e;
          --green-dark: #0f4a1e;
          --black: #030d05;
          --text-muted: #7dab89;
          --font-display: 'Bebas Neue', sans-serif;
          --font-body: 'Rajdhani', sans-serif;
        }

        body {
          background-color: var(--black);
          color: #e8f5e9;
          font-family: var(--font-body);
          min-height: 100vh;
          display: flex;
          flex-direction: column;
        }

        /* ── SPLASH ── */
        #splash-overlay {
          position: fixed;
          inset: 0;
          background: #000;
          z-index: 9999;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          gap: 2rem;
          animation: splash-exit 0.7s ease-in-out 2.4s forwards;
          pointer-events: none;
        }

        @keyframes splash-exit {
          0%   { opacity: 1; transform: scale(1); }
          100% { opacity: 0; transform: scale(1.05); visibility: hidden; }
        }

        .splash-logo {
          font-family: var(--font-display);
          font-size: 5.5rem;
          letter-spacing: 0.06em;
          line-height: 1;
          animation: splash-logo-in 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
        }

        @keyframes splash-logo-in {
          0%   { opacity: 0; transform: scale(0.5) translateY(30px); filter: blur(10px); }
          100% { opacity: 1; transform: scale(1) translateY(0);      filter: blur(0); }
        }

        .splash-lucky { color: #fff; text-shadow: 0 0 30px rgba(57,255,20,0.3); }
        .splash-bet   { color: var(--green-bright); text-shadow: 0 0 30px var(--green-bright), 0 0 70px rgba(57,255,20,0.4); }

        .splash-chips {
          position: absolute;
          inset: 0;
          pointer-events: none;
          overflow: hidden;
        }

        .chip {
          position: absolute;
          top: -60px;
          border-radius: 50%;
          border: 4px solid var(--green-bright);
          box-shadow: 0 0 12px rgba(57,255,20,0.5);
          background: radial-gradient(circle at 35% 35%, #1a6e2e, #0a2e10);
          animation: chip-fall linear forwards;
        }

        .chip:nth-child(1) { left: 8%;  width: 30px; height: 30px; animation-duration: 1.4s; animation-delay: 0.1s; }
        .chip:nth-child(2) { left: 22%; width: 52px; height: 52px; animation-duration: 1.7s; animation-delay: 0.3s; }
        .chip:nth-child(3) { left: 45%; width: 44px; height: 44px; animation-duration: 1.5s; animation-delay: 0.0s; }
        .chip:nth-child(4) { left: 68%; width: 36px; height: 36px; animation-duration: 1.6s; animation-delay: 0.2s; }
        .chip:nth-child(5) { left: 86%; width: 28px; height: 28px; animation-duration: 1.3s; animation-delay: 0.4s; }
        .chip:nth-child(6) { left: 35%; width: 22px; height: 22px; animation-duration: 1.9s; animation-delay: 0.15s; }
        .chip:nth-child(7) { left: 58%; width: 48px; height: 48px; animation-duration: 1.45s; animation-delay: 0.35s; }
        .chip:nth-child(8) { left: 8%;  width: 30px; height: 30px; animation-duration: 1.4s; animation-delay: 0.95s; }
        .chip:nth-child(9) { left: 40%; width: 52px; height: 52px; animation-duration: 1.7s; animation-delay: 0.95s; }
        .chip:nth-child(10) { left: 45%; width: 44px; height: 44px; animation-duration: 1.5s; animation-delay: 0.05s; }
        .chip:nth-child(11) { left: 60%; width: 36px; height: 36px; animation-duration: 1.6s; animation-delay: 0.55s; }
        .chip:nth-child(12) { left: 65%; width: 28px; height: 28px; animation-duration: 1.3s; animation-delay: 0.65s; }
        .chip:nth-child(13) { left: 70%; width: 22px; height: 22px; animation-duration: 1.9s; animation-delay: 0.75s; }
        .chip:nth-child(14) { left: 10%; width: 48px; height: 48px; animation-duration: 1.45s; animation-delay: 0.85s; }

        @keyframes chip-fall {
          0%   { top: -70px; opacity: 1; transform: rotate(0deg); }
          80%  { opacity: 1; }
          100% { top: 110vh;  opacity: 0; transform: rotate(800deg); }
        }

        .splash-bar {
          width: 280px;
          height: 3px;
          background: rgba(57,255,20,0.12);
          border-radius: 2px;
          overflow: hidden;
          animation: splash-logo-in 0.4s ease 0.5s both;
        }

        .splash-bar__fill {
          height: 100%;
          width: 0%;
          background: linear-gradient(90deg, #22c55e, var(--green-bright));
          border-radius: 2px;
          box-shadow: 0 0 12px var(--green-bright);
          animation: bar-fill 2s cubic-bezier(0.4, 0, 0.2, 1) 0.4s forwards;
        }

        @keyframes bar-fill {
          0%   { width: 0%; }
          100% { width: 100%; }
        }

        .splash-tagline {
          font-family: var(--font-body);
          font-size: 0.75rem;
          font-weight: 700;
          letter-spacing: 0.3em;
          color: rgba(57,255,20,0.5);
          text-transform: uppercase;
          animation: splash-logo-in 0.4s ease 0.7s both;
        }

        /* ── VIDEO BG ── */
        .lb-bg-video {
          position: fixed;
          inset: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
          z-index: 0;
          opacity: 0.67;
        }

        .lb-bg-overlay {
          position: fixed;
          inset: 0;
          background: rgba(0, 0, 0, 0.05);
          z-index: 1;
          pointer-events: none;
        }

        main, .lb-header, .lb-footer {
          position: relative;
          z-index: 2;
        }

        /* ── HEADER ── */
        .lb-header {
          background: linear-gradient(180deg, rgba(0,0,0,0.95) 0%, rgba(3,15,5,0.92) 100%);
          border-bottom: 1px solid rgba(57, 255, 20, 0.2);
          position: sticky;
          top: 0;
          z-index: 100;
          box-shadow: 0 4px 30px rgba(0,0,0,0.6);
          backdrop-filter: blur(6px);
        }

        .lb-header__inner {
          max-width: 1280px;
          margin: 0 auto;
          padding: 0 2rem;
          height: 70px;
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 2rem;
        }

        .lb-logo {
          text-decoration: none;
          display: flex;
          align-items: baseline;
          flex-shrink: 0;
        }

        .lb-logo__lucky {
          font-family: var(--font-display);
          font-size: 2rem;
          color: #fff;
          letter-spacing: 0.04em;
          line-height: 1;
          text-shadow: 0 0 12px rgba(57,255,20,0.4);
        }

        .lb-logo__bet {
          font-family: var(--font-display);
          font-size: 2rem;
          color: var(--green-bright);
          letter-spacing: 0.04em;
          line-height: 1;
          text-shadow: 0 0 16px var(--green-bright);
        }

        .lb-nav {
          display: flex;
          align-items: center;
          gap: 0.25rem;
          flex: 1;
          justify-content: center;
        }

        .lb-nav a {
          font-family: var(--font-body);
          font-weight: 700;
          font-size: 0.95rem;
          letter-spacing: 0.08em;
          text-transform: uppercase;
          color: #cce8d0;
          text-decoration: none;
          padding: 0.45rem 1rem;
          border-radius: 4px;
          transition: color 0.2s;
          position: relative;
        }

        .lb-nav a::after {
          content: '';
          position: absolute;
          bottom: 0;
          left: 50%;
          transform: translateX(-50%);
          width: 0;
          height: 2px;
          background: var(--green-bright);
          transition: width 0.25s;
          box-shadow: 0 0 8px var(--green-bright);
          border-radius: 2px;
        }

        .lb-nav a:hover { color: #fff; }
        .lb-nav a:hover::after { width: 70%; }

        .lb-header__actions {
          display: flex;
          align-items: center;
          gap: 0.75rem;
          flex-shrink: 0;
        }

        .lb-btn {
          font-family: var(--font-body);
          font-weight: 700;
          font-size: 0.85rem;
          letter-spacing: 0.1em;
          text-transform: uppercase;
          text-decoration: none;
          padding: 0.55rem 1.4rem;
          border-radius: 5px;
          transition: all 0.2s;
          cursor: pointer;
          border: none;
          display: inline-block;
        }

        .lb-btn--outline {
          border: 1.5px solid rgba(57,255,20,0.5);
          color: #c8eacc;
          background: transparent;
        }
        .lb-btn--outline:hover {
          border-color: var(--green-bright);
          color: var(--green-bright);
          box-shadow: 0 0 12px rgba(57,255,20,0.25);
        }

        .lb-btn--primary {
          background: linear-gradient(135deg, #22c55e, #16a34a);
          color: #fff;
          box-shadow: 0 0 16px rgba(34,197,94,0.35);
        }
        .lb-btn--primary:hover {
          background: linear-gradient(135deg, var(--green-bright), #22c55e);
          box-shadow: 0 0 22px rgba(57,255,20,0.5);
          color: #000;
        }

        /* ── MAIN ── */
        main {
          flex: 1;
          min-height: 69vh;
        }

        /* ── FOOTER ── */
        .lb-footer {
          background: linear-gradient(0deg, rgba(0,0,0,0.97) 0%, rgba(2,12,4,0.93) 20%);
          border-top: 1px solid rgba(57, 255, 20, 0.15);
          margin-top: auto;
          backdrop-filter: blur(6px);
        }

        .lb-footer__top {
          max-width: 1280px;
          margin: 0 auto;
          padding: 3rem 2rem 2rem;
          display: grid;
          grid-template-columns: 1.6fr 1fr 1fr;
          gap: 2.5rem;
        }

        .lb-footer__brand .lb-logo {
          display: inline-flex;
          margin-bottom: 1rem;
        }

        .lb-footer__brand p {
          font-size: 0.85rem;
          color: var(--text-muted);
          line-height: 1.6;
          max-width: 280px;
        }

        .lb-footer__badges {
          display: flex;
          gap: 0.5rem;
          margin-top: 1.25rem;
          flex-wrap: wrap;
        }

        .lb-badge {
          font-size: 0.7rem;
          font-weight: 700;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          padding: 0.3rem 0.65rem;
          border-radius: 3px;
          border: 1px solid rgba(57,255,20,0.25);
          color: var(--text-muted);
        }

        .lb-footer__col h4 {
          font-family: var(--font-display);
          font-size: 1.1rem;
          letter-spacing: 0.08em;
          color: var(--green-bright);
          text-shadow: 0 0 8px rgba(57,255,20,0.4);
          margin-bottom: 1rem;
        }

        .lb-footer__col ul {
          list-style: none;
          display: flex;
          flex-direction: column;
          gap: 0.55rem;
        }

        .lb-footer__col ul li a {
          font-size: 0.88rem;
          color: var(--text-muted);
          text-decoration: none;
          transition: color 0.2s;
          font-weight: 500;
        }

        .lb-footer__col ul li a:hover { color: #fff; }

        .lb-footer__bottom {
          border-top: 1px solid rgba(255,255,255,0.05);
          padding: 1.25rem 2rem;
          max-width: 1280px;
          margin: 0 auto;
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 1rem;
          flex-wrap: wrap;
        }

        .lb-footer__legal {
          font-size: 0.75rem;
          color: #3a5e41;
          line-height: 1.5;
          max-width: 700px;
        }

        .lb-footer__18 {
          width: 36px;
          height: 36px;
          border-radius: 50%;
          border: 2px solid #3a5e41;
          display: flex;
          align-items: center;
          justify-content: center;
          font-weight: 700;
          font-size: 0.75rem;
          color: #3a5e41;
          flex-shrink: 0;
        }

  body
    #splash-overlay
      .splash-chips
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
        .chip
      .splash-logo
        span.splash-lucky Lucky
        span.splash-bet Bet
      .splash-tagline Your luck starts here
      .splash-bar
        .splash-bar__fill

    video.lb-bg-video autoplay="true" loop="true" muted="true" playsinline="true"
      source src="/background.webm" type="video/webm"
    .lb-bg-overlay

    header.lb-header
      .lb-header__inner
        a.lb-logo href="/"
          span.lb-logo__lucky Lucky
          span.lb-logo__bet Bet

        - if session[:user_id]
          nav.lb-nav
            a href="/upgrade" Upgrade
            a href="/play" Play
            a href="/shop" Shop
            a href="/orders" Orders
            a href="/edit_profile" Edit Profile

        .lb-header__actions
          - if session[:user_id]
            a.lb-btn.lb-btn--outline href="/logout" Logout
          - else
            a.lb-btn.lb-btn--outline href="/login" Login
            a.lb-btn.lb-btn--primary href="/register" Sign Up

    main
      == yield

    footer.lb-footer
      .lb-footer__top
        .lb-footer__brand
          a.lb-logo href="/"
            span.lb-logo__lucky Lucky
            span.lb-logo__bet Bet
          p Your premier destination for casino games, live dealers, and jackpots. Play responsibly and enjoy the thrill.
          .lb-footer__badges
            span.lb-badge 🔒 SSL Secured
            span.lb-badge ✔ Licensed
            span.lb-badge 🎲 Fair Play

        .lb-footer__col
          h4 My Account
          ul
            - if session[:user_id]
              li: a href="/upgrade" Upgrade
              li: a href="/play" Play
              li: a href="/shop" Shop
              li: a href="/orders" Orders
              li: a href="/edit_profile" Edit Profile
              li: a href="/logout" Logout
            - else
              li: a href="/login" Login
              li: a href="/register" Sign Up

        .lb-footer__col
          h4 Support
          ul
            li: a href="/responsible-gaming" Responsible Gaming
            li: a href="/terms" Terms & Conditions
            li: a href="/support" 24/7 Support

      .lb-footer__bottom
        p.lb-footer__legal
          | LuckyBet is licensed and regulated. Gambling can be addictive — please play responsibly. Must be 18+ to participate.
        .lb-footer__18 18+